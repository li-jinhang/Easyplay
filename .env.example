NODE_ENV=development
HOST=0.0.0.0
PORT=3000
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=2h
DB_PATH=./services/auth-system/data/auth.db
BCRYPT_ROUNDS=10
TRUST_PROXY=false
ENABLE_ACCESS_LOG=true

# Frontend hosting
ENABLE_FRONTEND=true
FRONTEND_ROOT=../../
FRONTEND_ENTRY=index.html
DEV_HOT_RELOAD=true

# CORS
CORS_ORIGIN=*
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_HEADERS=Origin,X-Requested-With,Content-Type,Accept,Authorization
CORS_CREDENTIALS=false

# Cache
STATIC_CACHE_MAX_AGE=31536000
HTML_CACHE_MAX_AGE=0

# HTTPS
ENABLE_HTTPS=false
HTTPS_KEY_PATH=./services/auth-system/certs/server.key
HTTPS_CERT_PATH=./services/auth-system/certs/server.crt

# HTTP server tuning
KEEP_ALIVE_TIMEOUT=65000
REQUEST_TIMEOUT=30000

# Game
# TURN_TIMEOUT_MS=60000
